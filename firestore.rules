rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function restaurantDoc(restaurantId) {
      return get(/databases/$(database)/documents/restaurants/$(restaurantId));
    }

    function isOwner(restaurantId) {
      return signedIn() && restaurantDoc(restaurantId).data.ownerUid == request.auth.uid;
    }

    function isStaff(restaurantId) {
      return signedIn() && request.auth.uid in restaurantDoc(restaurantId).data.staffUids;
    }

    function isViewer(restaurantId) {
      return signedIn() && request.auth.uid in restaurantDoc(restaurantId).data.viewerUids;
    }

    function canViewRestaurant(restaurantId) {
      return restaurantDoc(restaurantId).data.isPublic == true || isOwner(restaurantId) || isStaff(restaurantId) || isViewer(restaurantId);
    }

    match /restaurants/{restaurantId} {
      allow read: if resource.data.isPublic == true || isOwner(restaurantId) || isStaff(restaurantId) || isViewer(restaurantId);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isOwner(restaurantId);

      match /items/{itemId} {
        allow read: if canViewRestaurant(restaurantId);
        allow create, update, delete: if isOwner(restaurantId) || isStaff(restaurantId);
      }
    }
  }
}
